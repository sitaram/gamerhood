# Copy to .env.local and fill in real values (never commit .env.local).
# On a new machine: copy .env.local from 1Password / your password manager,
# or export from Vercel → Project → Settings → Environment Variables.

# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Site URLs ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Stripe (required for checkout) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CREATOR_COUNTRY=US

# ── Printful (required for mockups / fulfillment) ──
PRINTFUL_API_TOKEN=
PRINTFUL_STORE_ID=
PRINTFUL_WEBHOOK_SECRET=

# ── AI design generation (at least one path you use) ──
GEMINI_API_KEY=

# ── Optional ──
GOOGLE_CLOUD_VISION_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=Gamerhood <noreply@gamerhood.gg>
ADMIN_EMAILS=
